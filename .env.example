# Backend base URL — server-only, dùng cho rewrites() và serverFetch()
# Ví dụ: http://localhost:8080
BACKEND_URL=

# API base path — dùng cho axios client (browser), phải bắt đầu bằng /
# Ví dụ: /api/v1  (relative, đi qua Next.js rewrite proxy)
NEXT_PUBLIC_API_URL=

# Socket.IO server URL — dùng để kết nối WebSocket
# Ví dụ: http://localhost:8080
NEXT_PUBLIC_SOCKET_URL=

# SSE server URL — dùng cho Server-Sent Events (optional)
# Ví dụ: http://localhost:8080
NEXT_PUBLIC_SSE_URL=

# Site origin — dùng cho SEO metadata (metadataBase, canonical, hreflang, OG image, sitemap)
# Phải là absolute URL, không có dấu / ở cuối. Ví dụ: https://wordy.vn
# Bỏ trống ở local thì fallback http://localhost:3000
NEXT_PUBLIC_SITE_URL=
